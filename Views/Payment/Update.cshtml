@model PetConnect.ViewModels.PaymentViewModel
@using PetConnect.Domain.Enums

@{
    ViewData["Title"] = "Update Payment";
}


<h2>Update a Payment</h2>

<hr />

<form asp-controller="Payment"
      asp-action="Update"
      method="post">
    @Html.AntiForgeryToken()
    <input type="hidden" asp-for="Id" />
  
    <div asp-validation-summary="All" class="text-danger"></div>

    <!-- Payment Summary -->
    @if (Model.AdoptionId.HasValue)
    {
        <div class="alert alert-info mb-3">
            <strong>Adoption Payment</strong><br />
            Adoption ID: @Model.AdoptionId<br />
            Amount: $@Model.Amount
        </div>
    }

    <!-- Amount -->
    <div class="mb-3">
        <label asp-for="Amount" class="form-label"></label>
        <input asp-for="Amount" class="form-control" />
        <span asp-validation-for="Amount" class="text-danger"></span>
    </div>





    <!-- Payment Type -->
    <div class="mb-3">
        <label asp-for="Type" class="form-label"></label>
        <select asp-for="Type"
                asp-items="Html.GetEnumSelectList<PaymentType>()"
                class="form-select">
            <option value="">-- Select Payment Type --</option>
        </select>
        <span asp-validation-for="Type" class="text-danger"></span>
    </div>



    <!-- CASH / CARD -->
    <div class="mb-3">
        <label asp-for="FirstName" class="form-label"></label>
        <input asp-for="FirstName" class="form-control" />
    </div>

    <div class="mb-3">
        <label asp-for="LastName" class="form-label"></label>
        <input asp-for="LastName" class="form-control" />
    </div>

    <!-- CREDIT CARD -->
    <div class="mb-3">
        <label asp-for="LastFourDigits" class="form-label"></label>
        <input asp-for="LastFourDigits" class="form-control" maxlength="4" />
    </div>

    <!-- PAYPAL -->
    <div class="mb-3">
        <label asp-for="PaypalEmail" class="form-label"></label>
        <input asp-for="PaypalEmail" class="form-control" />
    </div>

    <!-- CHECK -->
    <div class="mb-3">
        <label asp-for="BankName" class="form-label"></label>
        <input asp-for="BankName" class="form-control" />
    </div>

    <div class="mb-3">
        <label asp-for="CheckNumber" class="form-label"></label>
        <input asp-for="CheckNumber" class="form-control" />
    </div>



    <div class="mt-3">
        <button type="submit" class="btn btn-primary">Update Payment</button>
        <a asp-action="Index" class="btn btn-secondary">Cancel</a>
    </div>
</form>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
}






