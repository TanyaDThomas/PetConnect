@model PetConnect.ViewModels.PaymentDetailsViewModel
@{
    ViewData["Title"] = "Payment Details";
}


<h2>Payment Details</h2>
<hr />


<div class="row">
    <div class="col-sm-6">
        <h4>Basic Information</h4>
        <hr />

        <dl>

            <dt class="col-sm-4">Amount
            <dd class="col-sm-8">@Model.Amount</dd>

            <dt class="col-sm-4">Payment Method </dt>
            <dd class="col-sm-8">@Model.Type</dd>

            <dt class="col-sm-4">Payment Date</dt>
            <dd class="col-sm-8">@Model.PaymentDate</dd>

            <dt class="col-sm-4">Animal Status</dt>
            <dd class="col-sm-8">@Model.Status</dd>

                <dt class="col-sm-4">Adoption Id</dt>
                <dd class="col-sm-8">@Model.AdoptionId</dd>

        
        </dl>
    </div>

    

</div>


<div class="mt-3">
    <a asp-action="Update" asp-route-id="@Model.Id" class="btn btn-warning">Update</a>

    <a asp-action="Index" class="btn btn-secondary">Back to List</a>
</div>


