@using PetConnect.Domain.Enums
@model PetConnect.ViewModels.PaymentViewModel

@{
    ViewData["Title"] = "Create Payment";
}

<h2>Create Payment</h2>
<hr />

<form asp-action="Create" method="post">

    @Html.AntiForgeryToken()

    <input type="hidden" asp-for="AdoptionId" />

    <div asp-validation-summary="All" class="text-danger"></div>

    <!-- Payment Summary -->
    @if (Model.AdoptionId.HasValue)
    {
        <div class="alert alert-info mb-3">
            <strong>Adoption Payment</strong><br />
            Adoption ID: @Model.AdoptionId<br />
            Amount: $@Model.Amount
        </div>
    }

    <!-- Amount (read-only so user can't change adoption fee) -->
    <div class="mb-3">
        <label asp-for="Amount" class="form-label"></label>
        <input asp-for="Amount" class="form-control" readonly />
       
    </div>

    <!-- Payment Type -->
    <div class="mb-3">
        <label asp-for="Type" class="form-label"></label>
        <select asp-for="Type"
                asp-items="Html.GetEnumSelectList<PaymentType>()"
                class="form-select">
            <option value="">-- Select Payment Type --</option>
        </select>
        <span asp-validation-for="Type" class="text-danger"></span>
    </div>

    <!-- Adopter (optional display only or hidden later via Identity) -->
    <div class="mb-3">
        <label asp-for="AdopterId" class="form-label"></label>
        <input asp-for="AdopterId" class="form-control" />
        <span asp-validation-for="AdopterId" class="text-danger"></span>
    </div>

    <!-- CASH / CARD -->
    <div class="mb-3">
        <label asp-for="FirstName" class="form-label"></label>
        <input asp-for="FirstName" class="form-control" />
    </div>

    <div class="mb-3">
        <label asp-for="LastName" class="form-label"></label>
        <input asp-for="LastName" class="form-control" />
    </div>

    <!-- CREDIT CARD -->
    <div class="mb-3">
        <label asp-for="LastFourDigits" class="form-label"></label>
        <input asp-for="LastFourDigits" class="form-control" maxlength="4" />
    </div>

    <!-- PAYPAL -->
    <div class="mb-3">
        <label asp-for="PaypalEmail" class="form-label"></label>
        <input asp-for="PaypalEmail" class="form-control" />
    </div>

    <!-- CHECK -->
    <div class="mb-3">
        <label asp-for="BankName" class="form-label"></label>
        <input asp-for="BankName" class="form-control" />
    </div>

    <div class="mb-3">
        <label asp-for="CheckNumber" class="form-label"></label>
        <input asp-for="CheckNumber" class="form-control" />
    </div>

  

    <div class="mt-3">
        <button type="submit" class="btn btn-primary">Submit Payment</button>
        <a asp-action="Index" class="btn btn-secondary">Cancel</a>
    </div>

</form>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
}