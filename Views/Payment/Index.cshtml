@model IEnumerable<PetConnect.ViewModels.PaymentListViewModel>

@{
    ViewData["Title"] = "List of Payments";
}



<div class="container">

    <!-- Header -->
    <div class="d-flex justify-content-between align-items-start mb-5">
        <div>
            <h1 class="header-title">Payments</h1>
            <p class="text-muted mb-0">6 of 6 transactions shown</p>
        </div>
        <a asp-action="Create" class="btn btn-add d-flex align-items-center gap-2">
            <i class="fas fa-plus"></i>
            Record Payment
        </a>
    </div>

    <!-- Main Card -->
    <div class="card shadow-sm border-0 rounded-4 overflow-hidden">

        <!-- Search Bar -->
        <div class="card-body pb-4">
            <div class="row g-3 align-items-center">
                <div class="col-lg-9">
                    <div class="position-relative">
                        <i class="fas fa-search position-absolute top-50 start-0 translate-middle-y ms-4 text-muted"></i>
                        <input type="text"
                               class="form-control search-input ps-5"
                               placeholder="Search by ID, adopter, or reference...">
                    </div>
                </div>
                <div class="col-lg-3">
                    <button class="btn btn-outline-secondary w-100 rounded-pill d-flex align-items-center justify-content-center gap-2 py-2">
                        <i class="fas fa-sliders"></i>
                        More filters
                    </button>
                </div>
            </div>
        </div>

        <!-- Species Filter -->
        <div class="card-body pt-0">
            <div class="d-flex align-items-center gap-3 mb-4">
                <span class="filter-label">Status:</span>
                <div class="d-flex flex-wrap gap-2">
                    <button class="pill-btn species-all active">All</button>
                    <button class="pill-btn btn-light text-dark">Paid</button>
                    <button class="pill-btn btn-light text-dark">Pending</button>
                    <button class="pill-btn btn-light text-dark">Failed</button>
                    <button class="pill-btn btn-light text-dark">Refunded</button>
                </div>

                
                <!-- Status Filter -->
                <div class="d-flex align-items-center gap-3 ms-5">
                    <span class="filter-label">Method:</span>
                    <div class="d-flex flex-wrap gap-2">
                        <button class="pill-btn status-all active">All</button>
                        <button class="pill-btn btn-light text-dark">Card</button>
                        <button class="pill-btn btn-light text-dark">Cash</button>
                        <button class="pill-btn btn-light text-dark">Check</button>
                        <button class="pill-btn btn-light text-dark">Paypal</button>
                    </div>
                </div>
            </div>

        </div>

    </div>

</div>

<hr />





<div class="container">

    <div class="table-container">
        <table class="table table-hover custom-table align-middle">
            <thead>
                <tr>
                    <th>Amount</th>
                    <th>Payment Date</th>
                    <th>Payment Method</th>
                    <th>Status</th>
                    <th>Actions</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var payment in Model)
                {
                    <tr>
                
                        <td>@payment.Amount </td>
                        <td>@payment.PaymentDate</td>
                        <td>@payment.PaymentMethod</td>
                        <td>@payment.Status</td>
                        <td class="d-flex gap-2">
                            <a asp-action="Details" asp-controller="Payment"
                               asp-route-id="@payment.Id"
                               class="btn btn-sm btn-info">Details</a>

                            <a asp-action="Update" asp-controller="Payment"
                               asp-route-id="@payment.Id"
                               class="btn btn-sm btn-warning">Update</a>

        

                            <form asp-action="Deactivate" asp-controller="Payment"
                                  asp-route-id="@payment.Id">
                                <button type="submit" class="btn btn-sm btn-danger">Remove</button>
                            </form>
                  
                        </td>
                    </tr>
                }
            </tbody>
            <tfoot></tfoot>
        </table>
    </div>
</div>


