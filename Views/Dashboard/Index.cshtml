@model PetConnect.ViewModels.DashboardViewModel
@using System.Text.Json

@{
    ViewData["Title"] = "Dashboard";
}

@* @{
    ViewData["Title"] = "Home Page";
} *@

@using System

@{
    var name = User.Identity?.Name ?? "Guest";

    var hour = DateTime.Now.Hour;

    var greeting = hour < 12 ? "Good Morning" :
                   hour < 18 ? "Good Afternoon" :
                                "Good Evening";
}



<div class="container-fluid">


    <h1 class="font-display">@greeting, @name  <span class="animate-wag">🐾</span> </h1>
    <p class="text-muted-foreground"> Here's what's happening across Pet Connect today.</p>

    <!-- Stats Cards -->
    <div class="row g-3 mb-4">

        <div class="col-md-3">
            <div class="dashboard-card">

                <div class="logo-circle bg-coral">
                    <i class="fa-solid fa-paw"></i>
                </div>

                <div>
                    <h6 class="card-title">Total Animals</h6>
                    <h3 class="card-number">@Model.TotalAnimals</h3>
                </div>
            </div>
        </div>

        <div class="col-md-3">
            <div class="dashboard-card">
                <div class="logo-circle bg-sage">
                    <i class="fa-solid fa-heart"></i>
                </div>

                <div>
                    <h6 class="card-title">Adoptions</h6>
                    <h3 class="card-number">@Model.Adoptions</h3>
                </div>
            </div>
        </div>


        <div class="col-md-3">
            <div class="dashboard-card">
                <div class="logo-circle bg-amber">
                    <i class="fa-solid fa-clock"></i>
                </div>

                <div>
                    <h6 class="card-title">Pending</h6>
                    <h3 class="card-number">@Model.PendingAdoptions</h3>

                </div>
            </div>
        </div>

        <div class="col-md-3">
            <div class="dashboard-card">
                <div class="logo-circle bg-blue">
                    <i class="fa-solid fa-dollar-sign"></i>
                </div>

                <div>
                    <h6 class="card-title">Revenue</h6>
                    <h3 class="card-number">$@Model.TotalRevenue</h3>
                </div>
            </div>
        </div>


    </div>
</div>
    
  
<!-- Add Cards -->

<div class="col-md-12 bg-coral">
    

            @* <h5 class="mb-4 centered white">
                VIEW AND ADD ANIMALS
            </h5> *@

</div>

<div class="animal-categories">


    

    <a href="/Animal?Name=&Breed=&MinAge=&MaxAge=&HasSpecialCareNeeds=&AnimalTypeId=8" class="category-card">
        <div class="emoji">🐕</div>
        <span>Dogs</span>
    </a>

    <a href="/Animal?Name=&Breed=&MinAge=&MaxAge=&HasSpecialCareNeeds=&AnimalTypeId=7" class="category-card">
        <div class="emoji">🐈</div>
        <span>Cats</span>
    </a>

    <a href="/Animal?Name=&Breed=&MinAge=&MaxAge=&HasSpecialCareNeeds=&AnimalTypeId=6" class="category-card">
        <div class="emoji">🐦</div>
        <span>Birds</span>
    </a>

    <a href="/Animal?Name=&Breed=&MinAge=&MaxAge=&HasSpecialCareNeeds=&AnimalTypeId=11" class="category-card">
        <div class="emoji">🐠</div>
        <span>Aquatic</span>
    </a>

    <a href="/Animal?Name=&Breed=&MinAge=&MaxAge=&HasSpecialCareNeeds=&AnimalTypeId=10" class="category-card">
        <div class="emoji">🐎</div>
        <span>Farm</span>
    </a>

    <a href="/Animal?Name=&Breed=&MinAge=&MaxAge=&HasSpecialCareNeeds=&AnimalTypeId=13" class="category-card">
        <div class="emoji">🐹</div>
        <span>Littles</span>
    </a>

    <a href="/Animal?Name=&Breed=&MinAge=&MaxAge=&HasSpecialCareNeeds=&AnimalTypeId=9" class="category-card">
        <div class="emoji">🦔</div>
        <span>Exotics</span>
    </a>

    <a href="/Animal?Name=&Breed=&MinAge=&MaxAge=&HasSpecialCareNeeds=&AnimalTypeId=12" class="category-card">
        <div class="emoji">🐢</div>
        <span>Reptiles</span>
    </a>

</div>


<!-- Add Others -->
<div class="row g-3 mb-4 mt-4">

    <div class="col-md-4">
        <a href="Adoption/Create">
        <div class="dashboard-card">

            <div class="logo-circle bg-blue">
                    <i class="fa-solid fa-heart"></i>
            </div>

            <div>
                <h5 class="card-title">Add Adoptions</h5>
          
            </div>
        </div>
            </a>
    </div>

    <div class="col-md-4">
        <a href="/Adopter/Create">
        <div class="dashboard-card">
            <div class="logo-circle bg-purple">
                <i class="fa-solid fa-user"></i>
            </div>

            <div>
                <h5 class="card-title">Add Adopter</h5>
                    
            </div>
        </div>
        </a>
    </div>


    <div class="col-md-4">
        <a href="/Shelter/Index">
        <div class="dashboard-card">
            <div class="logo-circle bg-teal">
                    <i class="bi bi-building"></i>
            </div>

            <div>
                <h5 class="card-title">View Shelters</h5>

            </div>
        </div>
        </a>
    </div>

  
    @* For Admin *@
    @if (User.IsInRole("Admin"))
    {
        <div class="col-md-4">
            <a href="/Admin/Create">
                <div class="dashboard-card">
                    <div class="logo-circle bg-coral">
                        <i class="bi bi-people"></i>
                    </div>

                    <div>
                        <h5 class="card-title">Add Staff</h5>

                    </div>
                </div>
            </a>
        </div>
        <div class="col-md-4">
            <a href="/AnimalType/Create">
                <div class="dashboard-card">
                    <div class="logo-circle bg-sage">
                        <i class="bi bi-tags-fill"></i>
                    </div>

                    <div>
                        <h5 class="card-title">Add Animal Type</h5>

                    </div>
                </div>
            </a>
        </div>
        <div class="col-md-4">
            <a href="/AttributeDefinition/Create">
                <div class="dashboard-card">
                    <div class="logo-circle bg-amber">
                        <i class="bi bi-list-check"></i>
                    </div>

                    <div>
                        <h5 class="card-title">Add Animal Attribute</h5>

                    </div>
                </div>
            </a>
        </div>            
    }
</div>
   

