@model PetConnect.ViewModels.ShelterViewModel
@{
    ViewData["Title"] = "Shelter Details";
}


<h2>Shelter Details</h2>
<hr />


<div class="row">
    <div class="col-sm-6">
        <h4>Basic Information</h4>
        <hr />

        <dl>
            <dt class="col-sm-4">Id</dt>
            <dd class="col-sm-8">@Model.Id</dd>

            <dt class="col-sm-4">Name</dt>
            <dd class="col-sm-8">@Model.Name</dd>

            <dt class="col-sm-4">Address </dt>
            <dd class="col-sm-8">@Model.Address</dd>

            <dt class="col-sm-4">City</dt>
            <dd class="col-sm-8">@Model.City</dd>

            <dt class="col-sm-4">State</dt>
            <dd class="col-sm-8">@Model.State</dd>

            <dt class="col-sm-4">Postal Code</dt>
            <dd class="col-sm-8">@Model.PostalCode</dd>

             <dt class="col-sm-4">Phone Number</dt>
            <dd class="col-sm-8">@Model.PhoneNumber</dd>

            <dt class="col-sm-4">Email</dt>
            <dd class="col-sm-8">@Model.Email</dd>

            <dt class="col-sm-4">Status</dt>
            <dd class="col-sm-8">@(Model.IsActive ? "Active" : "Inactive")</dd>

        </dl>
    </div>

</div>


<div class="mt-3">
    <a asp-action="Update" asp-route-id="@Model.Id" class="btn btn-warning">Update</a>

    <a asp-action="Index" class="btn btn-secondary">Back to List</a>
</div>

@* /////////////
/// NOTES ///
///////////// *@


<div class="mt-4">
    <div class="d-flex justify-content-between align-items-center">
        <h4>Recent Notes</h4>
        <div>
            <a asp-action="Create" asp-controller="Note"
               asp-route-entityType="@Model.EntityType"
               asp-route-entityId="@Model.Id"
               class="btn btn-sm btn-primary">Add Note</a>
            <a asp-action="Index" asp-controller="Note"
               asp-route-entityType="@Model.EntityType"
               asp-route-entityId="@Model.Id"
               class="btn btn-sm btn-secondary ms-2">View All Notes</a>
        </div>
    </div>
    <hr />

    @if (Model.RecentNotes.Any())
    {
        @foreach (var note in Model.RecentNotes)
        {
            <div class="card mb-2">
                <div class="card-body">
                    <strong>@note.Category</strong>
                    <span class="text-muted float-end">@note.CreatedOn.ToShortDateString()</span>
                    <p class="mb-0 mt-1">@note.Content</p>
                </div>
            </div>
        }
    }
    else
    {
        <p class="text-muted">No notes for this shelters yet.</p>
    }
</div>



<hr />
