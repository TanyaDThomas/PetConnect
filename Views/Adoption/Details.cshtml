@using PetConnect.Domain.Enums
@model PetConnect.ViewModels.AdoptionDetailsViewModel

@{
    ViewData["Title"] = "Adoption Details";
}


<h2>Adoption Details</h2>
<hr />


<div class="row">
    <div class="col-sm-6">
        <h4>Basic Information</h4>
        <hr />

        <dl>

            <dt class="col-sm-4">Shelter Name</dt>
            <dd class="col-sm-8">@Model.ShelterName</dd>

            <dt class="col-sm-4">Adopter </dt>
            <dd class="col-sm-8">@Model.AdopterName</dd>

            <dt class="col-sm-4">Animal Type</dt>
            <dd class="col-sm-8">@Model.AnimalType</dd>

            <dt class="col-sm-4">Animal Name</dt>
            <dd class="col-sm-8">@Model.AnimalName</dd>

        </dl>
    </div>

    <div class="col-md-6">
        <h4>Household Information</h4>
        <hr />

        <dl class="row">
            <dt class="col-sm-4">Adopter Fee</dt>
            <dd class="col-sm-8">@Model.AdoptionFee</dd>

            <dt class="col-sm-4">Adoption Date</dt>
            <dd class="col-sm-8">@Model.AdoptionDate</dd>

            <dt class="col-sm-4">Status</dt>
            <dd class="col-sm-8">@Model.Status</dd>

        </dl>
    </div>

</div>



<div class="row">
    <div class="col-sm-6">
<div class="mt-3">
    <a asp-action="Update" asp-route-id="@Model.Id" class="btn btn-warning">Update</a>

    <a asp-action="Index" class="btn btn-secondary">Back to List</a>
</div>
</div>

<div class="col-md-6">
        <div class="mt-3">
        @if (Model.PaymentStatus == PaymentStatus.Completed)
        {
            <button class="btn btn-success" disabled>
                Payment Completed
            </button>
        }
        else
        {
                <a asp-controller="Payment"
                       asp-action="Create"
                       asp-route-adoptionId="@Model.Id"
                       class="btn btn-success">
                    Make Payment
                </a>
        }
</div>
</div>
</div>


<div class="mt-4">
    <div class="d-flex justify-content-between align-items-center">
        <h4>Recent Notes</h4>
        <div>
            <a asp-action="Create" asp-controller="Note"
               asp-route-entityType="@Model.EntityType"
               asp-route-entityId="@Model.Id"
               class="btn btn-sm btn-primary">Add Note</a>
            <a asp-action="Index" asp-controller="Note"
               asp-route-entityType="@Model.EntityType"
               asp-route-entityId="@Model.Id"
               class="btn btn-sm btn-secondary ms-2">View All Notes</a>
        </div>
    </div>
    <hr />

    @if (Model.RecentNotes.Any())
    {
        @foreach (var note in Model.RecentNotes)
        {
            <div class="card mb-2">
                <div class="card-body">
                    <strong>@note.Category</strong>
                    <span class="text-muted float-end">@note.CreatedOn.ToShortDateString()</span>
                    <p class="mb-0 mt-1">@note.Content</p>
                </div>
            </div>
        }
    }
    else
    {
        <p class="text-muted">No notes for this adoption yet.</p>
    }
</div>



<hr />
