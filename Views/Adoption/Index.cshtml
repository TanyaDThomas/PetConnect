

@model PetConnect.ViewModels.AdoptionIndexViewModel
@using PetConnect.Domain.Enums

@{
    ViewData["Title"] = "List of Adoptions";
}

<form method="get" asp-action="Index">
    <div class="container">

        <!-- Header -->
        <div class="d-flex justify-content-between align-items-start mb-5">
            <div>
                <h1 class="header-title">Adoptions</h1>

                <p class="text-muted mb-0">
                    @Model.FilteredCount of @Model.TotalCount adoptions shown
                </p>
            </div>
            <a asp-action="Create" class="btn btn-add d-flex align-items-center gap-2">
                <i class="fas fa-plus"></i>
                Add Adoption
            </a>
        </div>

        
        <div class="card shadow-sm border-0 rounded-4 overflow-hidden">

            <!-- Search Bar -->
            <div class="card-body pb-4">
                <div class="row g-3 align-items-center">
                    <div class="col-lg-9">
                        <div class="position-relative">
                            <i class="fas fa-search position-absolute top-50 start-0 translate-middle-y ms-4 text-muted"></i>
                            <input type="text"
                                   class="form-control search-input ps-5"
                                   placeholder="Search by adoption ID, adopter, or animal..." />

                        </div>
                    </div>

            <!-- Filter Toggle -->
            <div class="col-lg-3">
                <button type="button"
                        class="btn btn-outline-secondary w-100 rounded-pill"
                        data-bs-toggle="collapse"
                        data-bs-target="#advancedFilters">
                    More filters
                </button>
            </div>
        </div>

        
        <div class="collapse mt-3" id="advancedFilters">
            <div class="card card-body">

                <div class="row g-3">

                    <div class="col-md-6">
                        <label class="form-label">Date From</label>

                        <input type="date"
                               name="AdoptionDateFrom"
                               value="@Model.Filter.AdoptionDateFrom?.ToString("yyyy-MM-dd")"
                               class="form-control" />
                    </div>

                   
                    <div class="col-md-6">
                        <label class="form-label">Date To</label>

                        <input type="date"
                               name="AdoptionDateTo"
                               value="@Model.Filter.AdoptionDateTo?.ToString("yyyy-MM-dd")"
                               class="form-control" />
                    </div>
                </div>

               
                <div class="mt-3 d-flex justify-content-end gap-2">

                    <a asp-action="Index" class="btn btn-light">
                        Clear
                    </a>

                    <button type="submit" class="btn btn-primary">
                        Apply Filters
                    </button>

                </div>

            </div>
        </div>

    </div>

    <hr />

    <!-- STATUS -->
    <div class="card-body pt-0">

        <div class="d-flex align-items-center gap-3 mb-4">

            <span class="filter-label">Status:</span>

            <div class="d-flex flex-wrap gap-2">

                <button type="submit"
                        name="Status"
                        value=""
                        class="pill-btn @(Model.Filter.Status == null ? "active" : "")">
                    All
                </button>

                <button type="submit"
                        name="Status"
                        value="@AdoptionStatus.Pending"
                        class="pill-btn @(Model.Filter.Status == AdoptionStatus.Pending ? "active" : "")">
                    Pending
                </button>

                <button type="submit"
                        name="Status"
                        value="@AdoptionStatus.Approved"
                        class="pill-btn @(Model.Filter.Status == AdoptionStatus.Approved ? "active" : "")">
                    Approved
                </button>

                <button type="submit"
                        name="Status"
                        value="@AdoptionStatus.Completed"
                        class="pill-btn @(Model.Filter.Status == AdoptionStatus.Completed ? "active" : "")">
                    Completed
                </button>

                <button type="submit"
                        name="Status"
                        value="@AdoptionStatus.Cancelled"
                        class="pill-btn @(Model.Filter.Status == AdoptionStatus.Cancelled ? "active" : "")">
                    Cancelled
                </button>

            </div>

        </div>

    </div>

   </div>

 </div>
</form>
<hr />
 



<!-- Content List -->
<div class="container">

    <div class="table-container">
        <table class="table table-hover custom-table align-middle">
           
                <thead>
                    <tr>
                        <th>Adopter Name</th>
                        <th>Animal Type</th>
                        <th>Animal Name</th>
                        <th>Adoption Date</th>
                        <th>Adoption Status</th>
                        <th>Actions</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var adoption in Model.Adoptions)
                    {
                        <tr>
                
                            <td>@adoption.AdopterName </td>
                            <td>@adoption.AnimalType</td>
                            <td>@adoption.AnimalName</td>
                            <td>@adoption.AdoptionDate</td>
                            <td>@adoption.Status</td>
                            <td class="d-flex gap-2">
                                <a asp-action="Details" asp-controller="Adoption"
                                   asp-route-id="@adoption.Id"
                                   class="btn btn-sm btn-info">Details</a>

                                <a asp-action="Update" asp-controller="Adoption"
                                   asp-route-id="@adoption.Id"
                                   class="btn btn-sm btn-warning">Update</a>

                                <form asp-action="Deactivate" asp-controller="Adoption"
                                      asp-route-id="@adoption.Id">
                                    <button type="submit" class="btn btn-sm btn-danger">Remove</button>
                                </form>
                  
                            </td>
                        </tr>
                    }
                </tbody>
                <tfoot></tfoot>
            </table>
    </div>
</div>



<div class="d-flex justify-content-between align-items-center mt-4 text-muted small">

    <div>
        Showing <strong>@Model.Adoptions.Count()</strong> adoptions
    </div>

    <div>
        Total in system: <strong>@Model.Adoptions.Count()</strong>
    </div>

</div>