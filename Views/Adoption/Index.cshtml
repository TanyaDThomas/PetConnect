

@model PetConnect.ViewModels.AdoptionIndexViewModel
@using PetConnect.Domain.Enums

@{
    ViewData["Title"] = "List of Adoptions";
}
<form method="get" asp-action="Index">
    <div class="container">

        <!-- Header -->
        <div class="d-flex justify-content-between align-items-start mb-5">
            <div>
                <h1 class="header-title">Adoptions</h1>

                <p class="text-muted mb-0">
                    @Model.FilteredCount of @Model.TotalCount adoptions shown
                </p>
            </div>
            <a asp-action="Create" class="btn btn-add d-flex align-items-center gap-2">
                <i class="fas fa-plus"></i>
                Add Animal
            </a>
        </div>
 


        <!-- SEARCH + FILTERS -->
        <div class="card-body pb-4">

            <div class="row g-3 align-items-center">

                <!-- SEARCH -->
                <div class="col-lg-9">
                    <input type="text"
                           name="SearchTerm"
                           value="@Model.Filter.SearchTerm"
                           class="form-control search-input"
                           placeholder="Search..." />
                </div>

                <!-- TOGGLE -->
                <div class="col-lg-3">
                    <button type="button"
                            class="btn btn-outline-secondary w-100"
                            data-bs-toggle="collapse"
                            data-bs-target="#advancedFilters">
                        More filters
                    </button>
                </div>

            </div>

            <!-- ADVANCED FILTERS -->
            <div class="collapse mt-3" id="advancedFilters">

                <div class="card card-body">

                    <input type="date"
                           name="AdoptionDateFrom"
                           value="@Model.Filter.AdoptionDateFrom?.ToString("yyyy-MM-dd")" />

                    <input type="date"
                           name="AdoptionDateTo"
                           value="@Model.Filter.AdoptionDateTo?.ToString("yyyy-MM-dd")" />

                    <div class="mt-3">
                        <button type="submit" class="btn btn-primary">Apply</button>
                        <a asp-action="Index" class="btn btn-light">Clear</a>
                    </div>

                </div>

            </div>

            <!-- STATUS PILLS -->
            <div class="d-flex gap-2 mt-3">

                <button type="submit" name="Status" value=""
                        class="pill-btn @(Model.Filter.Status == null ? "active" : "")">
                    All
                </button>

                <button type="submit" name="Status" value="Pending"
                        class="pill-btn @(Model.Filter.Status == AdoptionStatus.Pending ? "active" : "")">
                    Pending
                </button>

                <button type="submit" name="Status" value="Approved"
                        class="pill-btn @(Model.Filter.Status == AdoptionStatus.Approved ? "active" : "")">
                    Approved
                </button>

                <button type="submit" name="Status" value="Completed"
                        class="pill-btn @(Model.Filter.Status == AdoptionStatus.Completed ? "active" : "")">
                    Completed
                </button>

                <button type="submit" name="Status" value="Cancelled"
                        class="pill-btn @(Model.Filter.Status == AdoptionStatus.Cancelled ? "active" : "")">
                    Cancelled
                </button>

            </div>

        </div>

    </div>
       

 

  
  
</form>


<hr />
 

           

<!-- Content List -->
<div class="container">

    <div class="table-container">
        <table class="table table-hover custom-table align-middle">
           
                <thead>
                    <tr>
                        <th>Adopter Name</th>
                        <th>Animal Type</th>
                        <th>Animal Name</th>
                        <th>Adoption Date</th>
                        <th>Adoption Status</th>
                        <th>Actions</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var adoption in Model.Adoptions)
                    {
                        <tr>
                
                            <td>@adoption.AdopterName </td>
                            <td>@adoption.AnimalType</td>
                            <td>@adoption.AnimalName</td>
                            <td>@adoption.AdoptionDate</td>
                            <td>@adoption.Status</td>
                            <td class="d-flex gap-2">
                                <a asp-action="Details" asp-controller="Adoption"
                                   asp-route-id="@adoption.Id"
                                   class="btn btn-sm btn-info">Details</a>

                                <a asp-action="Update" asp-controller="Adoption"
                                   asp-route-id="@adoption.Id"
                                   class="btn btn-sm btn-warning">Update</a>

                                <form asp-action="Deactivate" asp-controller="Adoption"
                                      asp-route-id="@adoption.Id">
                                    <button type="submit" class="btn btn-sm btn-danger">Remove</button>
                                </form>
                  
                            </td>
                        </tr>
                    }
                </tbody>
                <tfoot></tfoot>
            </table>
    </div>
</div>



<div class="d-flex justify-content-between align-items-center mt-4 text-muted small">

    <div>
        Showing <strong>@Model.Adoptions.Count()</strong> adoptions
    </div>

    <div>
        Total in system: <strong>@Model.Adoptions.Count()</strong>
    </div>

</div>