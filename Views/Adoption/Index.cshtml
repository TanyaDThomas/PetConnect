@model IEnumerable<PetConnect.ViewModels.AdoptionListViewModel>

@{
    ViewData["Title"] = "List of Adoptions";
}



<div class="container">

    <!-- Header -->
    <div class="d-flex justify-content-between align-items-start mb-5">
        <div>
            <h1 class="header-title">Adoptions</h1>
            <p class="text-muted mb-0">6 of 6 adoptions shown</p>
        </div>
        <a asp-action="Create" class="btn btn-add d-flex align-items-center gap-2">
            <i class="fas fa-plus"></i>
            Add Adoption
        </a>
    </div>

    <!-- Main Card -->
    <div class="card shadow-sm border-0 rounded-4 overflow-hidden">

        <!-- Search Bar -->
        <div class="card-body pb-4">
            <div class="row g-3 align-items-center">
                <div class="col-lg-9">
                    <div class="position-relative">
                        <i class="fas fa-search position-absolute top-50 start-0 translate-middle-y ms-4 text-muted"></i>
                        <input type="text"
                               class="form-control search-input ps-5"
                               placeholder="Search by adoption ID, adopter, or animal...">
                    </div>
                </div>
                <div class="col-lg-3">
                    <button class="btn btn-outline-secondary w-100 rounded-pill d-flex align-items-center justify-content-center gap-2 py-2">
                        <i class="fas fa-sliders"></i>
                        More filters
                    </button>
                </div>
            </div>
        </div>

        <!-- Species Filter -->
        <div class="card-body pt-0">
            <div class="d-flex align-items-center gap-3 mb-4">
                <span class="filter-label">Status:</span>
                <div class="d-flex flex-wrap gap-2">
                    <button class="pill-btn species-all active">All</button>
                    <button class="pill-btn btn-light text-dark">Pending</button>
                    <button class="pill-btn btn-light text-dark">Approved</button>
                    <button class="pill-btn btn-light text-dark">Completed</button>
                    <button class="pill-btn btn-light text-dark">Cancelled</button>
                </div>

               
            </div>

        </div>

    </div>

</div>

<hr />





<div class="container">

    <div class="table-container">
        <table class="table table-hover custom-table align-middle">
           
                <thead>
                    <tr>
                        <th>Adopter Name</th>
                        <th>Animal Type</th>
                        <th>Animal Name</th>
                        <th>Adoption Date</th>
                        <th>Adoption Status</th>
                        <th>Actions</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var adoption in Model)
                    {
                        <tr>
                
                            <td>@adoption.AdopterName </td>
                            <td>@adoption.AnimalType</td>
                            <td>@adoption.AnimalName</td>
                            <td>@adoption.AdoptionDate</td>
                            <td>@adoption.Status</td>
                            <td class="d-flex gap-2">
                                <a asp-action="Details" asp-controller="Adoption"
                                   asp-route-id="@adoption.Id"
                                   class="btn btn-sm btn-info">Details</a>

                                <a asp-action="Update" asp-controller="Adoption"
                                   asp-route-id="@adoption.Id"
                                   class="btn btn-sm btn-warning">Update</a>

                                <form asp-action="Deactivate" asp-controller="Adoption"
                                      asp-route-id="@adoption.Id">
                                    <button type="submit" class="btn btn-sm btn-danger">Remove</button>
                                </form>
                  
                            </td>
                        </tr>
                    }
                </tbody>
                <tfoot></tfoot>
            </table>
    </div>
</div>

<nav aria-label="Page navigation">
    <ul class="pagination justify-content-center mt-3">
        <li class="page-item disabled">
            <a class="page-link">Previous</a>
        </li>
        <li class="page-item"><a class="page-link" href="#">1</a></li>
        <li class="page-item"><a class="page-link" href="#">2</a></li>
        <li class="page-item"><a class="page-link" href="#">3</a></li>
        <li class="page-item">
            <a class="page-link" href="#">Next</a>
        </li>
    </ul>
</nav>