
@model PetConnect.ViewModels.AdopterIndexViewModel

@{
    ViewData["Title"] = "List of Adopters";
}


<div class="container">

    <!-- Header -->
    <div class="d-flex justify-content-between align-items-start mb-5">
        <div>
            <h1 class="header-title">Adopters</h1>

            <p class="text-muted mb-0">
                @Model.FilteredCount of @Model.TotalCount adopters shown
            </p>
        </div>
        <a asp-action="Create" class="btn btn-add d-flex align-items-center gap-2">
            <i class="fas fa-plus"></i>
            Add Adopter
        </a>
    </div>

    <!-- Main Card -->
    <div class="card shadow-sm border-0 rounded-4 overflow-hidden">

        <!-- Search Bar -->
        <div class="card-body pb-4">
            <div class="row g-3 align-items-center">
                <div class="col-lg-9">
                    <div class="position-relative">
                        <i class="fas fa-search position-absolute top-50 start-0 translate-middle-y ms-4 text-muted"></i>
                        <input type="text"
                               class="form-control search-input ps-5"
                               placeholder="Search by name, email, ID or location..."/>
                    </div>
                </div>

                <div class="col-lg-3">
                  
                    <button type="button"
                            class="btn btn-outline-secondary w-100 rounded-pill"
                            data-bs-toggle="collapse"
                            data-bs-target="#advancedFilters">
                        More filters
                    </button>

                    <div class="collapse mt-3" id="advancedFilters">
                        <div class="card card-body">

                            <div class="row g-3">

                               

                                <div class="col-md-8">
                                    <label class="form-label">Has Children</label>
                                    <select name="HasChildren" class="form-select">
                                        <option value="true">Yes</option>
                                        <option value="false">No</option>
                                    </select>
                                </div>

                                <div class="col-md-8">
                                    <label class="form-label">Has Yard</label>
                                    <select name="HasYard" class="form-select">
                                        <option value="true">Yes</option>
                                        <option value="false">No</option>
                                    </select>
                                </div>
                            </div>

                            <div class="mt-3 d-flex justify-content-end gap-2">
                                <a asp-action="Index" class="btn btn-light">
                                    Clear
                                </a>

                                <button type="submit" class="btn btn-primary">
                                    Apply Filters
                                </button>
                            </div>

                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>
<hr />




<div class="container">

    <div class="table-container">
        <table class="table table-hover custom-table align-middle">
    <thead>
        <tr>
            <th>Full Name</th>
            <th>Phone Number</th>
            <th>Email Address</th>
            <th>Shelter</th>
            <th>Actions</th>
        </tr>
    </thead>
    <tbody>
        @foreach(var adopter in Model.Adopters)
        {
            <tr>
                
                <td>@adopter.FullName </td>
                <td>@adopter.PhoneNumber</td>
                <td>@adopter.Email</td>
                <td>@adopter.ShelterName</td>
                <td class="d-flex gap-2">
                    <a asp-action="Details" asp-controller="Adopter"
                        asp-route-id="@adopter.Id"
                        class="btn btn-sm btn-info">Details</a>

                    <a asp-action="Update" asp-controller="Adopter"
                       asp-route-id="@adopter.Id"
                       class="btn btn-sm btn-warning">Update</a>

                    <form asp-action="Deactivate" asp-controller="Adopter"
                          asp-route-id="@adopter.Id"
                          method="post"
                          style="display:inline">

                        @Html.AntiForgeryToken()

                        <button type="submit" class="btn btn-sm btn-danger">
                            Remove
                        </button>
                    </form>
                  
                </td>
            </tr>
        }
    </tbody>
    <tfoot></tfoot>
</table>
    </div>
</div>

        <div class="d-flex justify-content-between align-items-center mt-4 text-muted small">

            <div>
                Showing <strong>@Model.Adopters.Count()</strong> adopters
            </div>

            <div>
                Total in system: <strong>@Model.Adopters.Count()</strong>
            </div>

        </div>