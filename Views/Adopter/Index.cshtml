@model IEnumerable<PetConnect.ViewModels.AdopterListViewModel>

@{
    ViewData["Title"] = "List of Adopters";
}


<div class="container">

    <!-- Header -->
    <div class="d-flex justify-content-between align-items-start mb-5">
        <div>
            <h1 class="header-title">Adopters</h1>
            <p class="text-muted mb-0">6 of 6 adopters shown</p>
        </div>
        <a asp-action="Create" class="btn btn-add d-flex align-items-center gap-2">
            <i class="fas fa-plus"></i>
            Add Adopter
        </a>
    </div>

    <!-- Main Card -->
    <div class="card shadow-sm border-0 rounded-4 overflow-hidden">

        <!-- Search Bar -->
        <div class="card-body pb-4">
            <div class="row g-3 align-items-center">
                <div class="col-lg-9">
                    <div class="position-relative">
                        <i class="fas fa-search position-absolute top-50 start-0 translate-middle-y ms-4 text-muted"></i>
                        <input type="text"
                               class="form-control search-input ps-5"
                               placeholder="Search by name, email, ID or location...">
                    </div>
                </div>
                <div class="col-lg-3">
                    <button class="btn btn-outline-secondary w-100 rounded-pill d-flex align-items-center justify-content-center gap-2 py-2">
                        <i class="fas fa-sliders"></i>
                        More filters
                    </button>
                </div>
            </div>
        </div>

        <!-- Species Filter -->
        <div class="card-body pt-0">
            <div class="d-flex align-items-center gap-3 mb-4">
                <span class="filter-label">Status:</span>
                <div class="d-flex flex-wrap gap-2">
                    <button class="pill-btn species-all active">All</button>
                    <button class="pill-btn btn-light text-dark">Active</button>
                    <button class="pill-btn btn-light text-dark">Pending Review</button>
                    <button class="pill-btn btn-light text-dark">Flagged</button>
                    <button class="pill-btn btn-light text-dark">Inactive</button>
                </div>

                

            </div>

        </div>

    </div>

</div>

<hr />




<div class="container">

    <div class="table-container">
        <table class="table table-hover custom-table align-middle">
    <thead>
        <tr>
            <th>Full Name</th>
            <th>Phone Number</th>
            <th>Email Address</th>
            <th>Shelter</th>
            <th>Actions</th>
        </tr>
    </thead>
    <tbody>
        @foreach(var adopter in Model)
        {
            <tr>
                
                <td>@adopter.FullName </td>
                <td>@adopter.PhoneNumber</td>
                <td>@adopter.Email</td>
                <td>@adopter.ShelterName</td>
                <td class="d-flex gap-2">
                    <a asp-action="Details" asp-controller="Adopter"
                        asp-route-id="@adopter.Id"
                        class="btn btn-sm btn-info">Details</a>

                    <a asp-action="Update" asp-controller="Adopter"
                       asp-route-id="@adopter.Id"
                       class="btn btn-sm btn-warning">Update</a>

                    <form asp-action="Deactivate" asp-controller="Adopter"
                          asp-route-id="@adopter.Id"
                          method="post"
                          style="display:inline">

                        @Html.AntiForgeryToken()

                        <button type="submit" class="btn btn-sm btn-danger">
                            Remove
                        </button>
                    </form>
                  
                </td>
            </tr>
        }
    </tbody>
    <tfoot></tfoot>
</table>
    </div>
</div>

