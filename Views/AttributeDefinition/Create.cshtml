
@model PetConnect.Domain.Entities.AttributeDefinition
@using PetConnect.Domain.Enums

@{
    ViewData["Title"] = "Create Animal Attribute";
}

<div class="container">

    <h2>Create Animal Attribute</h2>
    <hr />

    <form asp-action="Create" method="post">

        @Html.AntiForgeryToken()

        <div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>

        <div class="row">

            <div class="col-md-6 mb-3">
                <label asp-for="Name" class="form-label"></label>

                <input asp-for="Name" class="form-control" />

                <span asp-validation-for="Name" class="text-danger"></span>
            </div>

            <div class="col-md-6 mb-3">
                <label asp-for="DataType" class="form-label"></label>

                <select asp-for="DataType"
                        asp-items="Html.GetEnumSelectList<AttributeDataType>()"
                        class="form-select">
                    <option value="">-- Select Data Type --</option>
                </select>

                <span asp-validation-for="DataType" class="text-danger"></span>
            </div>

        </div>

        <div class="mt-3">

            <button type="submit"
                    class="btn btn-primary"
                    onclick="disableButton(this)">
                Save Attribute
            </button>

            <a asp-action="Index"
                   class="btn btn-secondary">
                Cancel
            </a>

        </div>

    </form>

</div>

@section Scripts
{
    <partial name="_ValidationScriptsPartial" />
}

