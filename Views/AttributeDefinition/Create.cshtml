@model PetConnect.Domain.Entities.AttributeDefinition
@using PetConnect.Domain.Enums

@{
    ViewData["Title"] = "Create a New Animal Attribute";
}

<h2>Create a New Animal Attribute</h2>
<hr />

<form asp-action="Create">
    @Html.AntiForgeryToken()
    <div asp-validation-summary="All" class="text-danger"></div>


    <div class="row mb-3 d-flex">
   
        <div class="col-sm-6">
            <label asp-for="DataType" class="form-label"></label>

            <select asp-for="DataType"
                    asp-items="Html.GetEnumSelectList<AttributeDataType>()"
                    class="form-select">
                <option value="">-- Select Data Type --</option>
            </select>

            <span asp-validation-for="DataType" class="text-danger"></span>
        </div>

        <div class="col-sm-6">
            <label asp-for="Name" class="form-label"></label>
            <input asp-for="Name" class="for-control" />


            <span asp-validation-for="DataType" class="text-danger"></span>
        </div>
    </div>

    <div class="mt-3">
        <button type="submit" class="btn btn-primary">Save</button>
        <a asp-action="Index" class="btn btn-secondary">Cancel</a>
    </div>
</form>


@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
}



