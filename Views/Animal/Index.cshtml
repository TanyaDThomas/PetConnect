<div class="d-flex justify-content-between align-items-center mt-4 text-muted small">
    <div>
        Showing <strong>@Model.FilteredCount</strong> animals
    </div>

    <div>
        Total in system: <strong>@Model.TotalCount</strong>
    </div>
</div>

