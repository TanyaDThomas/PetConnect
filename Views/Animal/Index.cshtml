
@model PetConnect.ViewModels.AnimalIndexViewModel

@{
    ViewData["Title"] = "List of Animals";
}


<form method="get" asp-action="Index" asp-controller="Animal">
    <div class="container">

        <!-- Header -->
        <div class="d-flex justify-content-between align-items-start mb-5">
            <div>
                <h1 class="header-title">Animals</h1>
                <p class="text-muted mb-0">
                    @Model.FilteredCount of @Model.TotalCount animals shown
                </p>
            </div>
            <a asp-action="Create" class="btn btn-add d-flex align-items-center gap-2">
                <i class="fas fa-plus"></i>
                Add Animal
            </a>
        </div>

        <!-- Main Card -->
        <div class="card shadow-sm border-0 rounded-4 overflow-hidden">

            <!-- Search Bar -->
            <div class="card-body pb-4">
                <div class="row g-3 align-items-center">
                    <div class="col-lg-9">
                        <div class="position-relative">
                            <i class="fas fa-search position-absolute top-50 start-0 translate-middle-y ms-4 text-muted"></i>
                            <input type="text"
                                   name="Name"
                                   value="@Model.Filter.Name"
                                   class="form-control search-input ps-5"
                                   placeholder="Search by name, breed, or ID..." />
                        
                        </div>
                    </div>
                    <div class="col-lg-3">
                  
                        <button type="button"
                                class="btn btn-outline-secondary w-100 rounded-pill"
                                data-bs-toggle="collapse"
                                data-bs-target="#advancedFilters">
                            More filters
                        </button>

                        <div class="collapse mt-3" id="advancedFilters">
                            <div class="card card-body">

                                <div class="row g-3">

                                    <div class="col-md-4">
                                        <label class="form-label">Breed</label>
                                        <input type="text"
                                               name="Breed"
                                               value="@Model.Filter.Breed"
                                               class="form-control" />
                                    </div>

                                    <div class="col-md-4">
                                        <label class="form-label">Min Age</label>
                                        <input type="number"
                                               name="MinAge"
                                               value="@Model.Filter.MinAge"
                                               class="form-control" />
                                    </div>

                                    <div class="col-md-4">
                                        <label class="form-label">Max Age</label>
                                        <input type="number"
                                               name="MaxAge"
                                               value="@Model.Filter.MaxAge"
                                               class="form-control" />
                                    </div>

                                    <div class="col-md-8">
                                        <label class="form-label">Special Care</label>
                                        <select name="HasSpecialCareNeeds" class="form-select">
                                            <option value="">Any</option>
                                            <option value="true">Yes</option>
                                            <option value="false">No</option>
                                        </select>
                                    </div>

                                </div>

                                <div class="mt-3 d-flex justify-content-end gap-2">
                                    <a asp-action="Index" class="btn btn-light">
                                        Clear
                                    </a>

                                    <button type="submit" class="btn btn-primary">
                                        Apply Filters
                                    </button>
                                </div>

                            </div>
                        </div>
                    </div>
                </div>
            </div>

            <!-- Species Filter -->
            <div class="card-body pt-0">
                <div class="d-flex align-items-center gap-3 mb-4">
                    <span class="filter-label">Species:</span>
                    <div class="d-flex flex-wrap gap-2">

                        <button type="submit"
                                name="AnimalTypeId"
                                value=""
                                class="pill-btn @(Model.Filter.AnimalTypeId == null ? "active" : "")">
                            All
                        </button>

                        @foreach (var type in Model.AnimalTypes)
                        {
                            <button type="submit"
                                    name="AnimalTypeId"
                                    value="@type.Id"
                                    class="pill-btn @(Model.Filter.AnimalTypeId == type.Id ? "active" : "")">
                                @type.Name
                            </button>
                        }

                    </div>
                

                <!-- Status Filter -->
                <div class="d-flex align-items-center gap-3 ms-5">
                    <span class="filter-label">Status:</span>
                    <div class="d-flex flex-wrap gap-2">
                            <button type="submit"
                                    name="IsAvailable"
                                    value=""
                                    class="pill-btn @(Model.Filter.IsAvailable == null ? "active" : "")">
                                All
                            </button>

                            <button type="submit"
                                    name="IsAvailable"
                                    value="true"
                                    class="pill-btn @(Model.Filter.IsAvailable == true ? "active" : "")">
                                Available
                            </button>

                            <button type="submit"
                                    name="IsAvailable"
                                    value="false"
                                    class="pill-btn @(Model.Filter.IsAvailable == false ? "active" : "")">
                                Adopted
                            </button>
                    </div>
                </div>
            </div>

            </div>

        </div>

    </div>
</form>

    <hr />
    
<div class="container">

    <div class="table-container">
        <table class="table table-hover custom-table align-middle">
                <thead>
                    <tr>
                        <th>Name</th>
                        <th>Animal Type </th>
                        <th>Breed</th>
                        <th>Adoption Status</th>
                        <th>Shelter</th>
                        <th>Actions</th>
                    </tr>
                </thead>
                <tbody>
                    @* @foreach (var animal in Model) *@
                @foreach (var animal in Model.Animals)
                    {
                        <tr>
                
                            <td>@animal.Name </td>
                            <td>@animal.AnimalTypeName </td>
                            <td>@animal.Breed</td>
                            <td>
                                @(animal.IsAdopted ? "Adopted" : "Available")
                            </td>
                            <td>@animal.ShelterName</td>
                            <td class="d-flex gap-2">
                                <a asp-action="Details" asp-controller="Animal"
                                   asp-route-id="@animal.Id"
                                   class="btn btn-sm btn-info">Details</a>

                                <a asp-action="Update" asp-controller="Animal"
                                   asp-route-id="@animal.Id"
                                   class="btn btn-sm btn-warning">Update</a>

                                <form asp-action="Deactivate" asp-controller="Animal"
                                      asp-route-id="@animal.Id">
                                    <button type="submit" class="btn btn-sm btn-danger">Remove</button>
                                </form>
                  
                            </td>
                        </tr>
                    }
                </tbody>
                <tfoot></tfoot>
           </table>
     </div>
 </div>


