@model PetConnect.ViewModels.AnimalViewModel
@{
    ViewData["Title"] = "Animal Details";
}


<h2>@Model.Name Details</h2>
<hr />


<div class="row">
    <div class="col-sm-6">
        <h4>Basic Information</h4>
        <hr />

        <dl>

            <dt class="col-sm-4">Full Name</dt>
            <dd class="col-sm-8">@Model.Name</dd>

            <dt class="col-sm-4">Animal Type</dt>
            <dd class="col-sm-8">@Model.AnimalTypeName</dd>

            <dt class="col-sm-4">Age</dt>
            <dd class="col-sm-8">@Model.Age</dd>

            <dt class="col-sm-4">Breed</dt>
            <dd class="col-sm-8">@Model.Breed</dd>

            <dt class="col-sm-4">Postal Color</dt>
            <dd class="col-sm-8">@Model.Color</dd>

            <dt class="col-sm-4">Adoption Fee</dt>
            <dd class="col-sm-8">@Model.AdoptionFee</dd>

            <dt class="col-sm-4">Status</dt>
            <dd class="col-sm-8">@(Model.IsAdopted ? "Adopted" : "Available")</dd>

            <dt class="col-sm-5">IsActive</dt>
            <dd class="col-sm-7">@(Model.IsActive ? "Yes" : "No")</dd>

            <dt class="col-sm-4">Shelter</dt>
            <dd class="col-sm-8">@Model.ShelterName</dd>

        </dl>
    </div>

    
    <div class="col-md-6">
        <h4>Additional Attributes</h4>
        <hr />

        @if (Model.Attributes != null && Model.Attributes.Any())
        {
            <dl class="row">
                @foreach (var attr in Model.Attributes)
                {
                    <dt class="col-sm-5">@attr.Name</dt>
                    <dd class="col-sm-7">@attr.Value</dd>
                }
            </dl>
        }
        else
        {
            <p class="text-muted">No additional attributes defined.</p>
        }
   

 
        <h4>Health Information</h4>
        <hr />

        <dl class="row">
            <dt class="col-sm-5">Vaccinated</dt>
            <dd class="col-sm-7">@(Model.IsVaccinated ? "Yes" : "No")</dd>

            <dt class="col-sm-5">Special Care Needs</dt>
            <dd class="col-sm-7">@(Model.HasSpecialCareNeeds ? "Yes" : "No")</dd>

            <dt class="col-sm-5">Has Special Diet</dt>
            <dd class="col-sm-7">@(Model.HasSpecialDiet ? "Yes" : "No")</dd>

        </dl>
    </div>



</div>



@* ///////////////
/// BUTTONS ///
/////////////// *@


<div class="mt-3">
    <a asp-action="Update" asp-route-id="@Model.Id" class="btn btn-warning">Update</a>

    <a asp-action="Index" class="btn btn-secondary">Back to List</a>
</div>


@* /////////////
/// NOTES ///
///////////// *@


<div class="mt-4">
    <div class="d-flex justify-content-between align-items-center">
        <h4>Recent Notes</h4>
        <div>
            <a asp-action="Create" asp-controller="Note"
               asp-route-entityType="@Model.EntityType"
               asp-route-entityId="@Model.Id"
               class="btn btn-sm btn-primary">Add Note</a>
            <a asp-action="Index" asp-controller="Note"
               asp-route-entityType="@Model.EntityType"
               asp-route-entityId="@Model.Id"
               class="btn btn-sm btn-secondary ms-2">View All Notes</a>
        </div>
    </div>
    <hr />

    @if (Model.RecentNotes.Any())
    {
        @foreach (var note in Model.RecentNotes)
        {
            <div class="card mb-2">
                <div class="card-body">
                    <strong>@note.Category</strong>
                    <span class="text-muted float-end">@note.CreatedOn.ToShortDateString()</span>
                    <p class="mb-0 mt-1">@note.Content</p>
                </div>
            </div>
        }
    }
    else
    {
        <p class="text-muted">No notes for this animal yet.</p>
    }
</div>



<hr />