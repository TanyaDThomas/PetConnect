@model PetConnect.ViewModels.AnimalViewModel

@{
    ViewData["Title"] = "Update Animal";
}

<h2>Update Animal Information</h2>
<hr />

<form asp-action="Update" method="post">
    @Html.AntiForgeryToken()
    <div asp-validation-summary="All" class="text-danger"></div>

    <!-- IDs (required for POST but not editable) -->
    <input type="hidden" asp-for="Id" />
    <input type="hidden" asp-for="ShelterId" />
    <input type="hidden" asp-for="AnimalTypeId" />

    <h4>Basic Information</h4>
    <hr />

    <div class="row mb-3">

        <!-- READ-ONLY DISPLAY -->
        <div class="col-sm-6">
            <label class="form-label">Shelter</label>
            <p class="form-control-plaintext">@Model.ShelterName</p>
        </div>

        <div class="col-sm-6">
            <label class="form-label">Animal Type</label>
            <p class="form-control-plaintext">@Model.AnimalTypeName</p>
        </div>

        <!-- EDITABLE FIELDS -->
        <div class="col-sm-6">
            <label asp-for="Name" class="form-label"></label>
            <input asp-for="Name" class="form-control" />
            <span asp-validation-for="Name" class="text-danger"></span>
        </div>

        <div class="col-md-6">
            <label asp-for="DateOfBirth" class="form-label"></label>
            <input asp-for="DateOfBirth" class="form-control" />
        </div>

        <div class="col-md-6">
            <label asp-for="Breed" class="form-label"></label>
            <input asp-for="Breed" class="form-control" />
        </div>

        <div class="col-md-6">
            <label asp-for="Color" class="form-label"></label>
            <input asp-for="Color" class="form-control" />
        </div>

        <div class="col-md-6">
            <label asp-for="AdoptionFee" class="form-label"></label>
            <input asp-for="AdoptionFee" class="form-control" />
        </div>

        <div class="col-md-6">
            <div class="form-check mt-4">
                <input asp-for="IsAdopted" class="form-check-input" />
                <label asp-for="IsAdopted" class="form-check-label"></label>
            </div>
        </div>

    </div>

    <h4>Health Information</h4>
    <hr />

    <div class="row mb-3">

        <div class="col-md-3">
            <div class="form-check">
                <input asp-for="IsVaccinated" class="form-check-input" />
                <label asp-for="IsVaccinated" class="form-check-label"></label>
            </div>
        </div>

        <div class="col-md-3">
            <div class="form-check">
                <input asp-for="HasSpecialCareNeeds" class="form-check-input" />
                <label asp-for="HasSpecialCareNeeds" class="form-check-label"></label>
            </div>
        </div>

        <div class="col-md-3">
            <div class="form-check">
                <input asp-for="HasSpecialDiet" class="form-check-input" />
                <label asp-for="HasSpecialDiet" class="form-check-label"></label>
            </div>
        </div>
    </div>

    <h4>Attributes</h4>
    <hr />

    @if (Model.Attributes != null && Model.Attributes.Any())
    {
        @for (int i = 0; i < Model.Attributes.Count; i++)
        {
            <div class="mb-3">

                <input type="hidden"
                       asp-for="Attributes[i].AttributeDefinitionId" />

                <label class="form-label">
                    @Model.Attributes[i].Name
                </label>

                <input asp-for="Attributes[i].Value"
                       class="form-control"
                       placeholder="Enter value..." />

            </div>
        }
    }
    else
    {
        <p class="text-muted">No attributes assigned to this animal type.</p>
    }

    <div class="mt-3">
        <button type="submit" class="btn btn-primary">Save Changes</button>
        <a asp-action="Index" class="btn btn-secondary">Cancel</a>
    </div>

</form>




@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
} 