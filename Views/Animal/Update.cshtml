@model PetConnect.ViewModels.AnimalViewModel

@{
    ViewData["Title"] = "Update Animal";
}

<h2>Update Animal Information</h2>
<hr />

<form asp-action="Update">
    @Html.AntiForgeryToken()
    <div asp-validation-summary="All" class="text-danger"></div>

    <h4>Basic Information</h4>
    <hr />


    <div class="row mb-3">
        @* WILL BE CHANGED LATER ONCE IDENTITY INSTALLED *@
        @* WILL BE CHANGED LATER ONCE IDENTITY INSTALLED *@
        @* WILL BE CHANGED LATER ONCE IDENTITY INSTALLED *@
        @* WILL BE CHANGED LATER ONCE IDENTITY INSTALLED *@
        <div class="col-sm-6">
            <div class="form-group">
                <label asp-for="ShelterId"></label>
                <select asp-for="ShelterId" asp-items="Model.Shelters" class="form-control">
                    <option value="">-- Select Shelter --</option>
                </select>
                <span asp-validation-for="ShelterId" class="text-danger"></span>
            </div>
        </div>

        <div class="col-sm-6">
            <div class="form-group">
                <label asp-for="AnimalTypeId"></label>
                <select asp-for="AnimalTypeId" asp-items="Model.AnimalTypes" class="form-control">
                    <option value="">-- Select Shelter --</option>
                </select>
                <span asp-validation-for="AnimalTypeId" class="text-danger"></span>
            </div>
        </div>

        <div class="col-sm-6">
            <label asp-for="Name" class="form-label">Name</label>
            <input asp-for="Name" class="form-control" />
            <span asp-validation-for="Name" class="text-danger"></span>
        </div>


        <div class="col-md-6">
            <label asp-for="DateOfBirth" class="form-label">Date Of Birth</label>
            <input asp-for="DateOfBirth" class="form-control" />
            <span asp-validation-for="DateOfBirth" class="text-danger"></span>
        </div>

        <div class="col-md-6">
            <label asp-for="Breed" class="form-label"></label>
            <input asp-for="Breed" class="form-control" />
            <span asp-validation-for="Breed" class="text-danger"></span>
        </div>

        <div class="col-md-6">
            <label asp-for="Color" class="form-label">Color</label>
            <input asp-for="Color" class="form-control" />
            <span asp-validation-for="Color" class="text-danger"></span>
        </div>

        <div class="col-md-6">
            <label asp-for="AdoptionFee" class="form-label">Adoption Fee</label>
            <input asp-for="AdoptionFee" class="form-control" />
            <span asp-validation-for="AdoptionFee" class="text-danger"></span>
        </div>

        <div class="col-md-6">
            <label asp-for="IsAdopted" class="form-label">Adoption Fee</label>
            <input asp-for="IsAdopted" class="form-control" />
            <span asp-validation-for="AdoptionFee" class="text-danger"></span>
        </div>

      
    </div>

    <h4>Health Information</h4>
    <hr>

    <div class="row mb-3">

        <div class="col-md-3">
            <div class="form-check">
                <input asp-for="IsVaccinated" class="form-check-input" />
                <label asp-for="IsVaccinated" class="form-check-label"></label>
            </div>
        </div>

        <div class="col-md-3">
            <div class="form-check">
                <input asp-for="HasSpecialCareNeeds" class="form-check-input" />
                <label asp-for="HasSpecialCareNeeds" class="form-check-label"></label>
            </div>
        </div>

        <div class="col-md-3">
            <div class="form-check">
                <input asp-for="HasSpecialDiet" class="form-check-input" />
                <label asp-for="HasSpecialDiet" class="form-check-label"></label>
            </div>
        </div>


    </div>

    <div class="mt-3">
        <button type="submit" class="btn btn-primary">Save Changes</button>
        <a asp-action="Index" class="btn btn-secondary">Cancel</a>
    </div>


</form>


@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
}
