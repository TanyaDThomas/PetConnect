@model PetConnect.ViewModels.AssignUserShelterViewModel

@{
    ViewData["Title"] = "Assign a user to a shelter";
}



<h2>Assign User To Shelter</h2>

<form asp-action="Create" method="post">
    @Html.AntiForgeryToken()
    <div asp-validation-summary="All" class="text-danger"></div>

    <div class="mb-3">
        <label>User</label>
        <select asp-for="UserId"
                asp-items="Model.Users"
                class="form-control">
        </select>
    </div>

    <div class="mb-3">
        <label>Shelter</label>
        <select asp-for="ShelterId"
                asp-items="Model.Shelters"
                class="form-control">
        </select>
    </div>

    @* <div class="form-group">
        <label>City</label>
        <input asp-for="City" class="form-control" />
    </div>

    <div class="form-group">
        <label>State</label>
        <input asp-for="State" class="form-control" />
    </div> *@

    <div class="mb-3">
        <label>Role</label>
        <select asp-for="RoleInShelter"
                asp-items="Model.Roles"
                class="form-control">
        </select>
    </div>

    <button type="submit" class="btn btn-primary">
        Assign User
    </button>

</form>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
}
