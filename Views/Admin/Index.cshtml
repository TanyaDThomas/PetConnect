@model IEnumerable<PetConnect.Domain.Entities.UserShelter>

@{
    ViewData["Title"] = "List of User Roles";
}

<h2>User Shelter Assignments</h2>

<hr />
<a asp-action="Create" class="btn btn-primary">
    Assign User
</a>
<hr />

<table class="table table-striped">
    <thead>
        <tr>
            <th>User</th>
            <th>Shelter</th>
            <th>City</th>
            <th>State</th>
            <th>Role</th>
            <th>Action</th>
        </tr>
    </thead>

    <tbody>
        @foreach (var item in Model)
        {
            <tr>
                <td>@item.User.UserName</td>
                <td>@item.Shelter.Name</td>
                <td>@item.Shelter.City</td>
                <td>@item.Shelter.State</td>
                <td>@item.RoleInShelter</td>

                <td class="d-flex gap-2">

                    <!-- UPDATE -->
                    <a asp-action="Update"
                           asp-route-userId="@item.UserId"
                           asp-route-shelterId="@item.ShelterId"
                           class="btn btn-warning btn-sm">
                        Update
                    </a>

                    <!-- DEACTIVATE -->
                    <form asp-action="Deactivate" method="post" class="d-inline">
                        @Html.AntiForgeryToken()

                        <input type="hidden" name="userId" value="@item.UserId" />
                        <input type="hidden" name="shelterId" value="@item.ShelterId" />

                        <button type="submit" class="btn btn-danger btn-sm">
                            Deactivate
                        </button>
                    </form>

                </td>
            </tr>
        }
    </tbody>
</table>


