@model IEnumerable<PetConnect.Domain.Entities.AnimalType>

@{
    ViewData["Title"] = "List of Animal Types";
}




<div class="container">

    <!-- Header -->
    <div class="d-flex justify-content-between align-items-start mb-5">
        <h2>View Animal Attributes</h2>
        <a asp-action="Create" class="btn btn-add d-flex align-items-center gap-2">
            <i class="fas fa-plus"></i>
            Add AnimalType
        </a>
    </div>
</div>
<hr />

<div class="container">

    <div class="table-container">
        <table class="table table-hover custom-table align-middle">

    <thead>
        <tr>
            <th>Animal Type</th>
            <th>Attributes</th>
            <th>Actions</th>
        </tr>
    </thead>
    <tbody>
        @foreach(var animalAttribute in Model)
        {
            <tr>
                <td>@animalAttribute.Name</td>
                <td class="d-flex gap-2">
                    <a asp-action="ViewAttributes"
                           asp-route-Id="@animalAttribute.Id"
                           class="btn btn-sm btn-secondary">
                        Manage Attributes
                    </a>
                </td>
                <td>
                    <form asp-action="Delete" asp-controller="AnimalType"
                        asp-route-id="@animalAttribute.Id"
                        method ="post"
                        style-display="inline">
                        @Html.AntiForgeryToken()
                        <button type="submit" class="btn btn-sm btn-danger">Delete</button>
                    </form>
                </td>
            </tr>

        }
    </tbody>
    <tfoot></tfoot>
</table>
    </div>
</div>