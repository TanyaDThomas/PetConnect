@model IEnumerable<PetConnect.Domain.Entities.Warning>

@{
    ViewData["Title"] = "List of Warnings";
}




<div class="container">

    <!-- Header -->
    <div class="d-flex justify-content-between align-items-start mb-5">
        <div>
            <h1 class="header-title">Warnings</h1>
            <p class="text-muted mb-0">6 of 6 warnings shown</p>
        </div>
        <a asp-action="Create" class="btn btn-add d-flex align-items-center gap-2">
            <i class="fas fa-plus"></i>
            Add Warning
        </a>
    </div>

    <!-- Main Card -->
    <div class="card shadow-sm border-0 rounded-4 overflow-hidden">

        <!-- Search Bar -->
        <div class="card-body pb-4">
            <div class="row g-3 align-items-center">
                <div class="col-lg-9">
                    <div class="position-relative">
                        <i class="fas fa-search position-absolute top-50 start-0 translate-middle-y ms-4 text-muted"></i>
                        <input type="text"
                               class="form-control search-input ps-5"
                               placeholder="Search by ID, adopter, or reason...">
                    </div>
                </div>
                <div class="col-lg-3">
                    <button class="btn btn-outline-secondary w-100 rounded-pill d-flex align-items-center justify-content-center gap-2 py-2">
                        <i class="fas fa-sliders"></i>
                        More filters
                    </button>
                </div>
            </div>
        </div>

        <!-- Species Filter -->
        <div class="card-body pt-0">
            <div class="d-flex align-items-center gap-3 mb-4">
                <span class="filter-label">Species:</span>
                <div class="d-flex flex-wrap gap-2">
                    <button class="pill-btn species-all active">All</button>
                    <button class="pill-btn btn-light text-dark">Low</button>
                    <button class="pill-btn btn-light text-dark">Medium</button>
                    <button class="pill-btn btn-light text-dark">High</button>
                    <button class="pill-btn btn-light text-dark">Critical</button>
                </div>

                
                <!-- Status Filter -->
                <div class="d-flex align-items-center gap-3 ms-5">
                    <span class="filter-label">Status:</span>
                    <div class="d-flex flex-wrap gap-2">
                        <button class="pill-btn status-all active">All</button>
                        <button class="pill-btn btn-light text-dark">Open</button>
                        <button class="pill-btn btn-light text-dark">Acknowledged</button>
                        <button class="pill-btn btn-light text-dark">Resolved</button>
                   
                    </div>
                </div>
            </div>

        </div>

    </div>

</div>

<hr />






<div class="container">

    <div class="table-container">
        <table class="table table-hover custom-table align-middle">
            <thead>
                <tr>
                    <th style="width: 5%;"></th>
                    <th>WARNING</th>
                    <th>ADOPTER</th>
                    <th>REASON</th>
                    <th>SEVERITY</th>
                    <th>STATUS</th>
                    <th>ISSUED</th>
                    <th style="width: 40px;"></th>
                </tr>
            </thead>
            <tbody>
                <!-- Row 1 -->
                <tr>
                    <td><div class="warning-icon bg-pink text-white"><i class="fas fa-exclamation-triangle"></i></div></td>
                    <td>
                        <div><strong class="id-column">WRN-3001</strong></div>
                        <div class="location">Westside</div>
                    </td>
                    <td>
                        <div class="d-flex align-items-center gap-3">
                            <div class="adopter-circle" style="background-color: #f97316;">EG</div>
                            <div>
                                <div><strong>Elena Garcia</strong></div>
                                <div class="text-muted small">AD-2385</div>
                            </div>
                        </div>
                    </td>
                    <td>
                        Missed scheduled vet check-in twice<br>
                        <span class="text-muted small">By Sarah Miller</span>
                    </td>
                    <td><span class="badge badge-pill severity-high">High</span></td>
                    <td><span class="badge badge-pill status-open">Open</span></td>
                    <td><i class="far fa-calendar text-muted"></i> Apr 13, 2025</td>
                    <td><button class="more-btn border-0">⋯</button></td>
                </tr>

                <!-- Row 2 -->
                <tr>
                    <td><div class="warning-icon bg-light text-muted"><i class="fas fa-exclamation-triangle"></i></div></td>
                    <td>
                        <div><strong class="id-column">WRN-3002</strong></div>
                        <div class="location">Downtown</div>
                    </td>
                    <td>
                        <div class="d-flex align-items-center gap-3">
                            <div class="adopter-circle" style="background-color: #f97316;">MH</div>
                            <div>
                                <div><strong>Marcus Holt</strong></div>
                                <div class="text-muted small">AD-2384</div>
                            </div>
                        </div>
                    </td>
                    <td>
                        Incomplete adoption application<br>
                        <span class="text-muted small">By James Wu</span>
                    </td>
                    <td><span class="badge badge-pill severity-low">Low</span></td>
                    <td><span class="badge badge-pill status-acknowledged">Acknowledged</span></td>
                    <td><i class="far fa-calendar text-muted"></i> Apr 11, 2025</td>
                    <td><button class="more-btn border-0">⋯</button></td>
                </tr>

                <!-- Add more rows following the same pattern as needed -->
            </tbody>
        </table>
    </div>

</div>



<nav aria-label="Page navigation">
    <ul class="pagination justify-content-center mt-3">
        <li class="page-item disabled">
            <a class="page-link">Previous</a>
        </li>
        <li class="page-item"><a class="page-link" href="#">1</a></li>
        <li class="page-item"><a class="page-link" href="#">2</a></li>
        <li class="page-item"><a class="page-link" href="#">3</a></li>
        <li class="page-item">
            <a class="page-link" href="#">Next</a>
        </li>
    </ul>
</nav>